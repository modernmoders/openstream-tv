<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only overlay: allow cleartext HTTP to the emulator's host-loopback
     address so local mock addons (MockWebServer / fixture servers on the dev
     machine) work in on-device testing (MASTER_PLAN §9.1, §7.2 acceptance
     test). Release builds keep the platform default: HTTPS only. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:networkSecurityConfig="@xml/network_security_config_debug"
        tools:replace="android:networkSecurityConfig"
        xmlns:tools="http://schemas.android.com/tools" />
</manifest>

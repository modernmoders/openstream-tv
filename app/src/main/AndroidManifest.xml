<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Addon protocol + streaming are network features -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Playback runs in a foreground MediaSessionService (§6.1) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Self-update (owner 2026-07-11): boxes leave the house, adb stops
         being a deploy path. Android still shows its own install
         confirmation; this only lets the app OFFER the update. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- TV-only app: leanback UI required, touchscreen explicitly not required
         so TV devices without touch can install it. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!-- Android 11+ package visibility: external player detection (§6.2)
         needs to see VLC/MX and whoever else handles video URLs. -->
    <queries>
        <package android:name="org.videolan.vlc" />
        <package android:name="com.mxtech.videoplayer.pro" />
        <package android:name="com.mxtech.videoplayer.ad" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="video/*" />
        </intent>
        <!-- Voice search: lets resolveActivity() see the system recognizer -->
        <intent>
            <action android:name="android.speech.action.RECOGNIZE_SPEECH" />
        </intent>
    </queries>

    <!-- usesCleartextTraffic: Stremio addons routinely serve plain-HTTP
         streams (Live-TV/IPTV especially — §8) and LAN fixtures are http.
         Blocking cleartext would silently kill those on release builds
         (found the hard way: R8 smoke test 2026-07-05, DECISIONS #21). -->
    <application
        android:name=".OpenStreamApp"
        android:label="${appLabel}"
        android:icon="@drawable/ic_launcher"
        android:banner="${appBanner}"
        android:theme="@style/Theme.OpenStream"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <!-- LEANBACK_LAUNCHER makes the app appear in the Android TV home screen -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Self-update plumbing: installer status callback + post-update
             relaunch (both internal, never exported). -->
        <receiver
            android:name=".update.UpdateStatusReceiver"
            android:exported="false" />
        <receiver
            android:name=".update.RelaunchAfterUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".player.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>
</manifest>
